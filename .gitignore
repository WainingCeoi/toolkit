# Root .gitignore — WHOLE-REPO concerns ONLY.
#
# The rule: this file lists only what belongs to no single sub-project — OS noise, editor
# state, agent scratch. Everything a sub-project owns lives in THAT sub-project's file:
# backend/.gitignore (.venv, __pycache__, .env, data/) and frontend/.gitignore
# (node_modules, dist). Don't restate them here.

# macOS / Windows
.DS_Store
Thumbs.db

# Editors
.idea/
.vscode/
*.swp

# Agent / assistant scratch
.claude/

# Legacy: the Streamlit-era root .env still exists on disk with real values
# (backend/.env is the live config now). Guarded here so it can never be
# committed by accident; delete the file and this line together.
/.env
