# frontend/.gitignore — NODE/FRONTEND ONLY.
#
# Shared OS/editor/agent patterns live in the ROOT .gitignore; don't repeat them here. Paths
# are relative to frontend/, so no `frontend/` prefix.

node_modules/

# Vite build output. `make build` regenerates it; `make start` / `make host` serve it.
dist/
dist-ssr/

# Local env overrides. Vite only exposes VITE_-prefixed vars to the browser — so a "secret"
# in any .env here ships to every client that loads the page. Don't put one there.
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
